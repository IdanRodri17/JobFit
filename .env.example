# ──────────────────────────────────────────────────────────
# JobFit — Environment Variables
# ──────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your actual values.
# NEVER commit your real `.env` file to git.
# ──────────────────────────────────────────────────────────

# ─── OpenAI ────────────────────────────────────────────
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ─── LangSmith (Tracing + Evaluation) ──────────────────
# Get yours at: https://smith.langchain.com/settings
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_your-langsmith-key-here
LANGCHAIN_PROJECT=JobFit
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ─── Tavily (Web Search Tool — used in V6) ─────────────
# Get yours at: https://tavily.com (free tier available)
# Leave blank until V6
TAVILY_API_KEY=

# ─── Application Settings ──────────────────────────────
# Override defaults from config/settings.py if needed
# MODEL_NAME=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# CHROMA_PERSIST_DIR=./data/chroma_db
